<?php

/**
 * @file
 * Provides basic integration with the GOV.UK Pay system.
 */

/**
 * Implements hook_theme().
 */
function govuk_pay_theme() {
  return [
    'govuk_payment_view' => [
      'variables' => [
        'payment' => NULL,
        'govukpayment' => NULL,
        'payment_events' => NULL,
      ],
      'template' => 'govuk-payment-view',
    ],
  ];
}
